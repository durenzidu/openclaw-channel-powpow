{
  "name": "@durenzidu/openclaw-channel-powpow",
  "version": "1.0.2",
  "id": "powpow-channel",
  "description": "PowPow 地图实时通信渠道插件，用于 OpenClaw 与 PowPow 数字人的双向实时消息传递",
  "type": "channel",
  "author": "durenzidu",
  "license": "MIT",
  "homepage": "https://github.com/durenzidu/openclaw-channel-powpow",
  "openclaw": {
    "compat": {
      "pluginApi": "1.0.0"
    },
    "build": {
      "openclawVersion": "2026.3.24"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/durenzidu/openclaw-channel-powpow.git"
  },
  "bugs": {
    "url": "https://github.com/durenzidu/openclaw-channel-powpow/issues"
  },
  "keywords": [
    "openclaw",
    "channel",
    "powpow",
    "map",
    "digital-human",
    "websocket",
    "real-time",
    "communication"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@openclaw/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@openclaw/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "clawhub": {
    "category": "channel",
    "tags": [
      "communication",
      "powpow",
      "map",
      "digital-human",
      "websocket",
      "real-time"
    ],
    "features": [
      "实时 WebSocket 通信",
      "流式输出支持",
      "多媒体消息（文本/图片/语音/视频）",
      "自动重连机制",
      "多账号实例支持",
      "访问控制（白名单/黑名单）",
      "Markdown 格式支持"
    ],
    "documentation": "docs/USER_GUIDE.md"
  },
  "configSchema": {
    "type": "object",
    "required": ["accounts"],
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "是否启用 Channel"
      },
      "accounts": {
        "type": "array",
        "description": "账号配置列表",
        "items": {
          "type": "object",
          "required": ["id", "digitalHumanId", "name"],
          "properties": {
            "id": {
              "type": "string",
              "description": "账号唯一标识"
            },
            "digitalHumanId": {
              "type": "string",
              "description": "PowPow 数字人 ID"
            },
            "name": {
              "type": "string",
              "description": "账号名称"
            },
            "wsUrl": {
              "type": "string",
              "format": "uri",
              "description": "WebSocket 地址",
              "default": "wss://global.powpow.online:8080"
            },
            "dmPolicy": {
              "type": "string",
              "enum": ["open", "allowlist", "blocklist"],
              "default": "open",
              "description": "私聊策略"
            },
            "allowFrom": {
              "type": "array",
              "items": { "type": "string" },
              "description": "白名单/黑名单用户 ID 列表"
            },
            "messageType": {
              "type": "string",
              "enum": ["text", "markdown"],
              "default": "markdown",
              "description": "消息类型"
            }
          }
        }
      },
      "advanced": {
        "type": "object",
        "description": "高级配置",
        "properties": {
          "autoReconnect": {
            "type": "boolean",
            "default": true,
            "description": "自动重连"
          },
          "reconnectInterval": {
            "type": "number",
            "default": 3000,
            "description": "重连间隔（毫秒）"
          },
          "maxReconnectAttempts": {
            "type": "number",
            "default": 10,
            "description": "最大重连次数"
          },
          "maxMessageLength": {
            "type": "number",
            "default": 2000,
            "description": "最大消息长度"
          },
          "enableStreaming": {
            "type": "boolean",
            "default": true,
            "description": "启用流式输出"
          },
          "enableCards": {
            "type": "boolean",
            "default": false,
            "description": "启用 AI 卡片"
          },
          "debug": {
            "type": "boolean",
            "default": false,
            "description": "调试模式"
          }
        }
      }
    }
  }
}
